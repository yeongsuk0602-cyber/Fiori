<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  controllerName="zrf4pp0002.controller.Main">
  <App id="app">
    <Page id="page" title="생산 실적 확정">
      <content>
        <VBox class="sapUiMediumMargin">
        <Panel id="searchPanel" width="100%">
          <headerToolbar>
            <Toolbar>
              <Title text="조회 조건"/>
              <ToolbarSpacer/>
              <Button text="Search" icon="sap-icon://search" type="Emphasized" press=".onSearch"/>
              <Button text="Reset" icon="sap-icon://reset" press=".onClearFilters"/>
            </Toolbar>
          </headerToolbar>
          <content>
            <VBox class="selectionArea">
              <HBox class="selectionRow" alignItems="Center">
                <Label text="Plant :" width="7rem"/>
                <Input id="werksInput" value="{view>/filters/WERKS}" width="8rem"/>
                <Label text="생산오더 :" width="7rem"/>
                <Input id="aufnrInput" value="{view>/filters/AUFNR}" width="12rem" placeholder="예: 1000001"/>
                <Label text="자재 번호 :" width="7rem"/>
                <Input id="matnrInput" value="{view>/filters/MATNR}" width="12rem" placeholder="예: MAT-1001"/>
              </HBox>
              <HBox class="selectionRow" alignItems="Center">
                <Label text="오더 상태 :" width="7rem"/>
                <Select id="statusSelect" selectedKey="{view>/filters/AUFST}" width="8rem">
                  <core:Item key="" text="전체"/>
                  <core:Item key="REL" text="REL"/>
                  <core:Item key="TECO" text="TECO"/>
                </Select>
                <Label text="생성일 From :" width="7rem"/>
                <DatePicker id="erdatFrom" value="{view>/filters/ERDAT_FROM}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" width="11rem"/>
                <Label text="To :" width="3rem"/>
                <DatePicker id="erdatTo" value="{view>/filters/ERDAT_TO}" valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd" width="11rem"/>
              </HBox>
            </VBox>
          </content>
        </Panel>

        <Panel id="orderPanel" headerText="조회 결과" expandable="true" expanded="true" class="sapUiSmallMarginTop">
          <content>
            <Table
              id="orderTable"
              mode="MultiSelect"
              includeItemInSelection="true"
              growing="true"
              growingThreshold="20"
              noDataText="조회 결과가 없습니다."
              selectionChange=".onSelectionChange">
              <headerToolbar>
                <Toolbar>
                  <Title text="생산오더 목록"/>
                  <ToolbarSpacer/>
                  <Button text="확정" icon="sap-icon://accept" type="Transparent" enabled="{view>/canConfirm}" press=".onConfirm"/>
                  <Button text="초기화" icon="sap-icon://reset" type="Transparent" press=".onReset"/>
                  <Button text="닫기" icon="sap-icon://decline" type="Transparent" press=".onClose"/>
                </Toolbar>
              </headerToolbar>
              <columns>
                <Column width="9rem"><Text text="생산오더"/></Column>
                <Column width="9rem"><Text text="계획오더"/></Column>
                <Column width="10rem"><Text text="자재"/></Column>
                <Column><Text text="자재명"/></Column>
                <Column width="6rem"><Text text="Plant"/></Column>
                <Column width="8rem"><Text text="공정표"/></Column>
                <Column hAlign="End" width="8rem"><Text text="목표수량"/></Column>
                <Column width="5rem"><Text text="단위"/></Column>
                <Column hAlign="End" width="8rem"><Text text="작업시간(H)"/></Column>
                <Column hAlign="End" width="8rem"><Text text="탄소(KG)"/></Column>
                <Column width="7rem"><Text text="상태"/></Column>
              </columns>
            </Table>
          </content>
        </Panel>

        <Panel id="confirmPanel" headerText="실적 입력" expandable="true" expanded="true" class="sapUiSmallMarginTop">
          <content>
            <VBox class="selectionArea">
              <HBox class="selectionRow" alignItems="Center">
                <Label text="양품 수량 :" width="8rem" required="true"/>
                <Input value="{view>/confirmation/YIELD_QTY}" type="Number" enabled="{view>/formEnabled}" width="10rem" liveChange=".onConfirmationInputChange"/>
                <Label text="불량 수량 :" width="8rem" required="true"/>
                <Input value="{view>/confirmation/SCRAP_QTY}" type="Number" enabled="{view>/formEnabled}" width="10rem" liveChange=".onConfirmationInputChange"/>
                <Label text="작업 시간 :" width="8rem"/>
                <Input value="{view>/confirmation/WORK_TIME}" type="Number" enabled="false" width="10rem"/>
              </HBox>
              <HBox class="selectionRow" alignItems="Center">
                <Label text="탄소 배출량 :" width="8rem"/>
                <Input value="{view>/confirmation/ACT_CARBON}" type="Number" enabled="false" width="10rem"/>
                <Label text="탄소 단위 :" width="8rem"/>
                <Select selectedKey="{view>/confirmation/ZCRB_MEINS}" enabled="{view>/formEnabled}" width="8rem">
                  <core:Item key="KG" text="KG"/>
                  <core:Item key="T" text="T"/>
                </Select>
                <Label text="검사 방식 :" width="8rem" required="true"/>
                <Select selectedKey="{view>/confirmation/INSP_MODE}" enabled="{view>/formEnabled}" width="8rem">
                  <core:Item key="AUTO" text="AUTO"/>
                  <core:Item key="MANU" text="MANU"/>
                </Select>
              </HBox>
              <HBox class="selectionRow" alignItems="Center">
                <Label text="검사 Lot :" width="8rem"/>
                <Input value="{view>/quality/Prueflos}" enabled="false" width="10rem"/>
                <Label text="배치 :" width="8rem"/>
                <Input value="{view>/quality/Charg}" enabled="false" width="10rem"/>
              </HBox>
              <HBox class="selectionRow" alignItems="Center">
                <Label text="품질 코드 :" width="8rem" required="true"/>
                <Select selectedKey="{view>/confirmation/VCODE}" enabled="{view>/formEnabled}" width="12rem">
                  <core:Item key="ACC" text="ACC - 합격"/>
                  <core:Item key="PAR" text="PAR - 부분합격"/>
                  <core:Item key="REJ" text="REJ - 불합격"/>
                </Select>
              </HBox>
            </VBox>
          </content>
        </Panel>
        </VBox>
      </content>
    </Page>
  </App>
</mvc:View>
